# =============================================================================
# SECRETS — do not commit real values
# =============================================================================

MONARCH_EMAIL=your@email.com
MONARCH_PASSWORD=yourpassword

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Finnhub (https://finnhub.io — free tier: 60 req/min)
FINNHUB_API_KEY=your-finnhub-api-key

# =============================================================================
# CONFIG — safe to share
# =============================================================================

# LLM profile: "gemma4" or "qwen3"
COMPOSE_PROFILES=gemma4

# Model file loaded by llama.cpp (override per profile as needed)
LLAMA_MODEL_FILE=gemma-4-it-Q4_K_M.gguf
# LLAMA_MODEL_FILE=Qwen3-8B-Q8_0.gguf

LLAMA_CPP_BASE_URL=http://llama:8080/v1
LLAMA_CPP_MODEL=gemma4
LLAMA_CPP_MAX_TOKENS=2048
LLAMA_CPP_TEMPERATURE=0.2

MONARCH_SESSION_FILE=.monarch_session.json
DB_PATH=data/finance.db
LOG_LEVEL=INFO
